<Window x:Class="VoiceInput.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VoiceInput.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="700" Height="150"
        IsHitTestVisible="False"
        Focusable="False">

    <!-- Fixed-size transparent host; the capsule is centered and its Width is animated,
         so the window never resizes and the pill grows/shrinks smoothly from its center. -->
    <Grid>
        <Border x:Name="Capsule"
                Height="56"
                CornerRadius="28"
                Padding="18,0"
                Width="160"
                ClipToBounds="True"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F22A2A2E" Offset="0" />
                    <GradientStop Color="#F21C1C1F" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#26FFFFFF" />
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.45" Color="#000000" />
            </Border.Effect>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <controls:WaveformControl x:Name="Wave"
                                          Width="44" Height="32"
                                          VerticalAlignment="Center"
                                          Margin="0,0,14,0" />
                <TextBlock x:Name="Label"
                           VerticalAlignment="Center"
                           MaxWidth="520"
                           Foreground="#FFF5F5F7"
                           FontSize="18"
                           FontWeight="Medium"
                           TextTrimming="None"
                           TextWrapping="NoWrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

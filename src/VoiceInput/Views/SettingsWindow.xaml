<Window x:Class="VoiceInput.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="gujiguji Setup"
        Width="900" Height="650" MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Background="#FAFAFA"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#2F7658" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#28664D" />
        <SolidColorBrush x:Key="TextBrush" Color="#242424" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B6B6B" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D8D8D8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#F1F1F1" />

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#BEBEBE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#BEBEBE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="BorderBrush" Value="#BEBEBE" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#BDBDBD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F0F2F1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#245F47" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#163E2D" />
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LinkButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="NavRadio" TargetType="RadioButton">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,0,0,3" />
            <Setter Property="Foreground" Value="#454545" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="NavBorder" Background="Transparent" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Indicator" Grid.Column="0" Width="3" Height="22"
                                        Background="Transparent" CornerRadius="2" />
                                <TextBlock Grid.Column="1" Text="{TemplateBinding Tag}"
                                           FontFamily="Segoe Fluent Icons" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <ContentPresenter Grid.Column="2" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#E4EEE8" />
                                <Setter TargetName="Indicator" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="#245F47" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#E8EAE9" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="NavBorder" Property="BorderThickness" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="PageSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,8,0,10" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#454545" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,7,14,7" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="184" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="64" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2" Grid.Column="0" Background="{StaticResource SidebarBrush}"
                BorderBrush="#DCDCDC" BorderThickness="0,0,1,0">
            <DockPanel Margin="11,19,11,14">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="gujiguji" Foreground="#777777" FontSize="11"
                               FontWeight="SemiBold" Margin="10,0,0,12" />
                    <RadioButton x:Name="OverviewNav" GroupName="SetupNavigation" Content="Overview"
                                 Tag="&#xE80F;" Style="{StaticResource NavRadio}" IsChecked="True"
                                 Checked="OnNavigationChanged" />
                    <RadioButton x:Name="ModelSelectionNav" GroupName="SetupNavigation" Content="Model Selection"
                                 Tag="&#xE720;" Style="{StaticResource NavRadio}"
                                 Checked="OnNavigationChanged" />
                    <RadioButton x:Name="ProfilesNav" GroupName="SetupNavigation" Content="Profiles"
                                 Tag="&#xE77B;" Style="{StaticResource NavRadio}"
                                 Checked="OnNavigationChanged" />
                    <RadioButton x:Name="VocabularyNav" GroupName="SetupNavigation" Content="Language intelligence"
                                 Tag="&#xE8C1;" Style="{StaticResource NavRadio}"
                                 Checked="OnNavigationChanged" />
                    <RadioButton x:Name="AppNav" GroupName="SetupNavigation" Content="App"
                                 Tag="&#xE713;" Style="{StaticResource NavRadio}"
                                 Checked="OnNavigationChanged" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom">
                    <Separator Margin="9,0,9,12" Background="#D9D9D9" />
                    <TextBlock Text="Settings are stored locally." Foreground="#707070"
                               FontSize="11" Margin="10,0,0,3" />
                    <TextBlock x:Name="VersionText" Foreground="#707070" FontSize="11" Margin="10,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Grid.Row="0" Margin="28,21,28,16">
            <ScrollViewer x:Name="OverviewPage" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Overview" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="Speech and refinement status"
                               Style="{StaticResource PageSubtitle}" />

                    <Border x:Name="OverviewBanner" Background="#FFFAF0" BorderBrush="#E4D4B7"
                            BorderThickness="4,1,1,1" CornerRadius="5" Padding="14,11" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="OverviewReadinessTitle" FontWeight="SemiBold" />
                                <TextBlock x:Name="OverviewReadinessText" Foreground="#65615A"
                                           FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button x:Name="ChooseModelButton" Grid.Column="1" Content="Choose a model"
                                    Style="{StaticResource PrimaryButton}" Margin="14,0,0,0"
                                    Click="OnChooseModel" />
                        </Grid>
                    </Border>

                    <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Margin="16,12">
                                <TextBlock Text="Active speech engine" FontWeight="SemiBold" />
                                <TextBlock Text="Used for new dictation sessions" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                            </StackPanel>
                            <TextBlock x:Name="OverviewActiveEngineText" Grid.Row="0" Grid.Column="1"
                                       VerticalAlignment="Center" Margin="16" Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold" />
                            <Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="16,0" />
                            <Grid Grid.Row="2" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel x:Name="OverviewLocalModelPanel" Grid.Column="0" Margin="16,12">
                                    <TextBlock Text="Local model" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                    <TextBlock x:Name="OverviewModelText" FontWeight="SemiBold" Margin="0,3,0,0" />
                                </StackPanel>
                                <StackPanel x:Name="OverviewLlmPanel" Grid.Column="1" Margin="16,12">
                                    <TextBlock Text="LLM refinement" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                    <TextBlock x:Name="OverviewLlmText" FontWeight="SemiBold" Margin="0,3,0,0" />
                                </StackPanel>
                                <StackPanel x:Name="OverviewLocalReadinessPanel" Grid.Column="2" Margin="16,12">
                                    <TextBlock Text="Local readiness" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                    <TextBlock x:Name="OverviewLocalStatusText" FontWeight="SemiBold" Margin="0,3,0,0" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="16,13">
                                <TextBlock Text="Voice activation" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                <TextBlock x:Name="OverviewPttText" FontWeight="SemiBold" Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="16,13">
                                <TextBlock Text="Recognition language" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                <TextBlock x:Name="OverviewLanguageText" FontWeight="SemiBold" Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="ModelSelectionPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Model Selection" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="Choose the recognition service or local model used for new dictation sessions."
                               Style="{StaticResource PageSubtitle}" Margin="0,0,0,12" />

                    <Border x:Name="ModelSelectionStatusBorder"
                            Background="#F4F8F5" BorderBrush="#BFD2C7" BorderThickness="4,1,1,1"
                            CornerRadius="5" Padding="13,9" Margin="0,0,0,8">
                        <TextBlock x:Name="ModelSelectionStatusText" TextWrapping="Wrap" />
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="EngineListLabel" Text="Speech engine" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="EngineList" Grid.Column="1" SelectionChanged="OnEngineChanged"
                                  HorizontalContentAlignment="Stretch"
                                  AutomationProperties.LabeledBy="{Binding ElementName=EngineListLabel}">
                            <ComboBoxItem Tag="Windows" Content="Windows dictation (built in)" />
                            <ComboBoxItem Tag="Azure" Content="Azure Speech (cloud)" />
                            <ComboBoxItem Tag="GptTranscribe" Content="GPT-4o Transcribe (cloud)" />
                            <ComboBoxItem Tag="FunAsr" Content="Local models (on-device)" />
                        </ComboBox>
                    </Grid>

                    <StackPanel x:Name="WindowsFieldsPanel" Margin="0,7,0,0">
                        <Separator Margin="0,0,0,12" />
                        <TextBlock Text="Windows dictation" Style="{StaticResource SectionTitle}" />
                        <Border Background="#FFFAF0" BorderBrush="#E4D4B7" BorderThickness="4,1,1,1"
                                CornerRadius="5" Padding="13,9">
                            <TextBlock Text="No setup required. Recognition quality is lower than the other options."
                                       TextWrapping="Wrap" Foreground="#744A08" />
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="AzureFieldsPanel" Margin="0,14,0,0">
                        <Separator Margin="0,0,0,12" />
                        <TextBlock Text="Azure Speech" Style="{StaticResource SectionTitle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Authentication" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="AzureAuthCombo" Grid.Row="0" Grid.Column="1"
                                      SelectionChanged="OnAzureAuthChanged">
                                <ComboBoxItem Content="Key (account key)" />
                                <ComboBoxItem Content="Microsoft Entra ID" />
                            </ComboBox>
                            <Grid x:Name="AzureKeyPanel" Grid.Row="1" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="AzureKeyLabel" Grid.Row="0" Text="Account key" Style="{StaticResource FieldLabel}" />
                                <PasswordBox x:Name="AzureKeyBox" Grid.Row="0" Grid.Column="1"
                                             AutomationProperties.LabeledBy="{Binding ElementName=AzureKeyLabel}" />
                                <TextBlock Grid.Row="1" Text="Region" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="AzureRegionBox" Grid.Row="1" Grid.Column="1" />
                            </Grid>
                            <Grid x:Name="AzureEntraPanel" Grid.Row="2" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Endpoint" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="AzureEndpointBox" Grid.Row="0" Grid.Column="1"
                                         ToolTip="https://resource.cognitiveservices.azure.com/" />
                                <TextBlock Grid.Row="1" Text="Tenant ID" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="AzureTenantIdBox" Grid.Row="1" Grid.Column="1" />
                            </Grid>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="TranscribeFieldsPanel" Margin="0,12,0,0">
                        <Separator Margin="0,0,0,12" />
                        <TextBlock Text="Foundry transcription" Style="{StaticResource SectionTitle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Authentication" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="TranscribeAuthCombo" Grid.Row="0" Grid.Column="1"
                                      SelectionChanged="OnTranscribeAuthChanged">
                                <ComboBoxItem Content="Key (account key)" />
                                <ComboBoxItem Content="Microsoft Entra ID" />
                            </ComboBox>
                            <TextBlock Grid.Row="1" Text="Endpoint" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="TranscribeEndpointBox" Grid.Row="1" Grid.Column="1" />
                            <TextBlock Grid.Row="2" Text="Model" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="TranscribeModelKindCombo" Grid.Row="2" Grid.Column="1">
                                <ComboBoxItem Content="GPT-4o Transcribe" />
                                <ComboBoxItem Content="GPT-4o Mini Transcribe" />
                                <ComboBoxItem Content="GPT-4o Transcribe Diarize (vocabulary unavailable)" />
                                <ComboBoxItem Content="Other / unknown" />
                            </ComboBox>
                            <TextBlock Grid.Row="3" Text="Deployment" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="TranscribeModelBox" Grid.Row="3" Grid.Column="1" />
                            <TextBlock x:Name="TranscribeApiKeyLabel" Grid.Row="4" Text="API key" Style="{StaticResource FieldLabel}" />
                            <PasswordBox x:Name="TranscribeApiKeyBox" Grid.Row="4" Grid.Column="1"
                                         AutomationProperties.LabeledBy="{Binding ElementName=TranscribeApiKeyLabel}" />
                            <TextBlock x:Name="TranscribeTenantLabel" Grid.Row="5" Text="Tenant ID" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="TranscribeTenantIdBox" Grid.Row="5" Grid.Column="1" />
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="LocalModelsPanel" Visibility="Collapsed" Margin="0,7,0,0">
                        <Separator Margin="0,0,0,12" />
                        <TextBlock Text="Local models" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Download only when needed. Packages are verified before activation, and downloading does not change your active model."
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,11" />
                        <Border Background="#F4F8F5" BorderBrush="#BFD2C7" BorderThickness="1"
                                CornerRadius="5" Padding="13,9" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Local runtime" FontWeight="SemiBold" />
                                    <TextBlock x:Name="FunAsrSummaryText" Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="No Python required" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"
                                           Margin="16,0,0,0" />
                            </Grid>
                        </Border>
                        <StackPanel x:Name="FunAsrModelsPanel" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="ProfilesPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Input Profiles" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="Activation and overlay presets for each Windows setup"
                               Style="{StaticResource PageSubtitle}" Margin="0,0,0,6" />

                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Profile switch shortcut" Style="{StaticResource FieldLabel}" />
                        <TextBlock Grid.Column="1" Text="Alt + Shift + G" VerticalAlignment="Center"
                                   FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                    </Grid>

                    <Border x:Name="Profile1Card" Background="White" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="15,8" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Profile 1" FontSize="15" FontWeight="SemiBold" />
                                <RadioButton x:Name="Profile1ActiveRadio" Grid.Column="1" Content="Active profile"
                                             GroupName="ActiveInputProfile" VerticalAlignment="Center" />
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Name" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="Profile1NameBox" Grid.Column="1" MaxLength="24" />
                            </Grid>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="1.65*" />
                                    <ColumnDefinition Width="0.85*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Activation key" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,2" />
                                    <ComboBox x:Name="Profile1KeyCombo" SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="RightCtrl" Content="Right Ctrl" />
                                        <ComboBoxItem Tag="LeftCtrl" Content="Left Ctrl" />
                                        <ComboBoxItem Tag="CapsLock" Content="Caps Lock" />
                                        <ComboBoxItem Tag="RightAlt" Content="Right Alt" />
                                        <ComboBoxItem Tag="RightShift" Content="Right Shift" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="Behavior" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,2" />
                                    <ComboBox x:Name="Profile1ModeCombo">
                                        <ComboBoxItem Content="Hold to talk" />
                                        <ComboBoxItem Content="Press once to start / stop" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Overlay" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,2" />
                                    <ComboBox x:Name="Profile1OverlayCombo">
                                        <ComboBoxItem Content="Top" />
                                        <ComboBoxItem Content="Bottom" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="Profile2Card" Background="White" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="15,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Profile 2" FontSize="15" FontWeight="SemiBold" />
                                <RadioButton x:Name="Profile2ActiveRadio" Grid.Column="1" Content="Active profile"
                                             GroupName="ActiveInputProfile" VerticalAlignment="Center" />
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Name" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="Profile2NameBox" Grid.Column="1" MaxLength="24" />
                            </Grid>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="1.65*" />
                                    <ColumnDefinition Width="0.85*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Activation key" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,2" />
                                    <ComboBox x:Name="Profile2KeyCombo" SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="RightCtrl" Content="Right Ctrl" />
                                        <ComboBoxItem Tag="LeftCtrl" Content="Left Ctrl" />
                                        <ComboBoxItem Tag="CapsLock" Content="Caps Lock" />
                                        <ComboBoxItem Tag="RightAlt" Content="Right Alt" />
                                        <ComboBoxItem Tag="RightShift" Content="Right Shift" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="Behavior" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,2" />
                                    <ComboBox x:Name="Profile2ModeCombo">
                                        <ComboBoxItem Content="Hold to talk" />
                                        <ComboBoxItem Content="Press once to start / stop" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Overlay" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,2" />
                                    <ComboBox x:Name="Profile2OverlayCombo">
                                        <ComboBoxItem Content="Top" />
                                        <ComboBoxItem Content="Bottom" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="VocabularyPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Language intelligence" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="Refinement, learning, and recognition vocabulary"
                               Style="{StaticResource PageSubtitle}" />

                    <TextBlock Text="Names and terms" Style="{StaticResource SectionTitle}" />
                    <Border x:Name="VocabularyEngineStatusBorder"
                            Background="#F4F8F5" BorderBrush="#BFD2C7" BorderThickness="4,1,1,1"
                            CornerRadius="5" Padding="14,11" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="135" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Current speech engine" Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11" />
                                <TextBlock x:Name="VocabularyCurrentEngineText" FontWeight="SemiBold"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <TextBlock x:Name="VocabularyModeText" Grid.Column="1"
                                       Margin="14,0,0,0" VerticalAlignment="Center"
                                       FontSize="12" TextAlignment="Left" TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="VocabularyTermsLabel" Text="Recognition terms"
                               Style="{StaticResource SectionTitle}" Margin="0,0,0,5" />
                    <TextBlock x:Name="VocabularySeparatorHintText"
                               Text="Separate terms with commas, semicolons, or new lines. Spaces inside a term are preserved."
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,8" />
                    <TextBox x:Name="VocabularyBox" Height="112" AcceptsReturn="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             AutomationProperties.LabeledBy="{Binding ElementName=VocabularyTermsLabel}" />
                    <DockPanel Margin="0,7,16,0">
                        <TextBlock x:Name="VocabularyCountText" DockPanel.Dock="Left"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                        <TextBlock Text="Stored locally - no local limit"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                                   TextAlignment="Right" />
                    </DockPanel>

                    <Separator Margin="0,20,0,10" />
                    <TextBlock Text="Language model connection" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Configure one OpenAI-compatible model. Setup alone does not enable refinement or send saved edits."
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,9" />
                    <Border Background="#F4F8F5" BorderBrush="#BFD2C7" BorderThickness="4,1,1,1"
                            CornerRadius="5" Padding="14,10" Margin="0,0,0,12">
                        <TextBlock x:Name="LlmConnectionStatusText" TextWrapping="Wrap" />
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="API base URL" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="LlmBaseUrlBox" Grid.Row="0" Grid.Column="1" />
                        <TextBlock x:Name="LlmApiKeyLabel" Grid.Row="1" Text="API key" Style="{StaticResource FieldLabel}" />
                        <PasswordBox x:Name="LlmApiKeyBox" Grid.Row="1" Grid.Column="1"
                                     AutomationProperties.LabeledBy="{Binding ElementName=LlmApiKeyLabel}" />
                        <TextBlock Grid.Row="2" Text="Model" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="LlmModelBox" Grid.Row="2" Grid.Column="1" />
                        <TextBlock Grid.Row="3" Text="Custom prompt" Style="{StaticResource FieldLabel}"
                                   VerticalAlignment="Top" />
                        <TextBox x:Name="LlmPromptBox" Grid.Row="3" Grid.Column="1" Height="96"
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top" />
                    </Grid>
                    <DockPanel Margin="150,12,0,0">
                        <Button x:Name="TestButton" DockPanel.Dock="Left" Content="Test connection"
                                Style="{StaticResource SecondaryButton}" Click="OnTest" />
                        <TextBlock x:Name="LlmTestStatusText" Margin="12,0,0,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                    </DockPanel>

                    <Separator Margin="0,20,0,10" />
                    <TextBlock Text="What it can do" Style="{StaticResource SectionTitle}" />
                    <CheckBox x:Name="LlmEnabledBox" Content="Refine each dictation"
                              FontWeight="SemiBold" />
                    <TextBlock Text="Correct recognition mistakes and follow the custom prompt above."
                               Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="20,1,0,8" />
                    <CheckBox x:Name="UseContextBox" Content="Use nearby app text for better refinement"
                              Margin="20,0,0,0"
                              AutomationProperties.HelpText="Nearby app text is sent only to your configured language model." />
                    <CheckBox x:Name="LearnFromEditsBox" Content="Save my corrections for learning"
                              FontWeight="SemiBold" Margin="0,10,0,0"
                              AutomationProperties.HelpText="Correction samples are encrypted for your Windows account and stored on this device." />
                    <TextBlock Text="Edit inserted text and press Enter in the same field. Samples stay encrypted locally; saving makes no network request."
                               Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="20,1,0,2" />
                    <TextBlock x:Name="CorrectionHistoryStatusText"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="20,0,0,0" />

                    <Separator Margin="0,20,0,10" />
                    <TextBlock Text="Learning from edits" Style="{StaticResource SectionTitle}" />
                    <TextBlock x:Name="LearningPrivacyText"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,9" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ReviewLearningButton" Content="Review learning"
                                Style="{StaticResource SecondaryButton}" Click="OnReviewLearning" />
                        <Button x:Name="ClearCorrectionHistoryButton" Content="Delete history"
                                Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                Click="OnClearCorrectionHistory" />
                        <TextBlock x:Name="LearningStatusText" Margin="12,0,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel x:Name="LearningReviewPanel" Visibility="Collapsed" Margin="0,14,0,0">
                        <StackPanel x:Name="LearnedRulesReviewPanel">
                            <CheckBox x:Name="ApplyLearnedRulesBox" Content="Use these correction rules"
                                      FontWeight="SemiBold" IsChecked="True" />
                            <TextBox x:Name="LearnedRulesPreviewBox" Height="84" Margin="20,5,0,12"
                                     IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                        <StackPanel x:Name="VocabularySuggestionsReviewPanel">
                            <TextBlock Text="Names and terms" FontWeight="SemiBold" />
                            <TextBlock Text="Uncheck anything you do not want to add."
                                       Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                                       Margin="0,1,0,5" />
                            <StackPanel x:Name="VocabularySuggestionsList" Margin="20,0,0,8" />
                        </StackPanel>
                        <Button x:Name="ApplyLearningButton" Content="Apply selected"
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                                Click="OnApplyLearning" />
                    </StackPanel>

                    <Separator Margin="0,20,0,10" />
                    <TextBlock Text="Model support" Style="{StaticResource SectionTitle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="112" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Supported" Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold" Margin="0,3,14,8" />
                        <TextBlock x:Name="VocabularySupportedModelsText" Grid.Row="0" Grid.Column="1"
                                   Text="Azure Speech (Phrase List, first 500), GPT-4o Transcribe, GPT-4o Mini Transcribe, and Qwen3-ASR 0.6B (prompt; first 10 terms, 96 characters)"
                                   TextWrapping="Wrap" Margin="0,3,0,8" />
                        <TextBlock Grid.Row="1" Text="Not supported" Foreground="#8C5709"
                                   FontWeight="SemiBold" Margin="0,3,14,0" />
                        <TextBlock x:Name="VocabularyUnsupportedModelsText" Grid.Row="1" Grid.Column="1"
                                   Text="Windows dictation, GPT-4o Transcribe Diarize, Other / unknown GPT deployments, and other local models"
                                   TextWrapping="Wrap" Margin="0,3,0,0" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="AppPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="App" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="Language, privacy, startup, and diagnostics"
                               Style="{StaticResource PageSubtitle}" />
                    <TextBlock Text="Dictation" Style="{StaticResource SectionTitle}" Margin="0,0,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Language" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="LanguageCombo" Grid.Row="0" Grid.Column="1" SelectedValuePath="Tag">
                            <ComboBoxItem Tag="en-US" Content="English" />
                            <ComboBoxItem Tag="zh-CN" Content="简体中文" />
                            <ComboBoxItem Tag="zh-TW" Content="繁體中文" />
                            <ComboBoxItem Tag="ja-JP" Content="日本語" />
                            <ComboBoxItem Tag="ko-KR" Content="한국어" />
                            <ComboBoxItem Tag="vi-VN" Content="Tiếng Việt" />
                        </ComboBox>
                    </Grid>

                    <Separator Margin="0,18,0,10" />
                    <TextBlock Text="Privacy and diagnostics" Style="{StaticResource SectionTitle}" />
                    <CheckBox x:Name="DiagnosticLoggingBox"
                              Content="Log transcript, vocabulary, and LLM output locally for diagnostics" />
                    <TextBlock x:Name="DiagnosticPrivacyText"
                               Text="Diagnostic logs stay on this device and are never uploaded to gujiguji servers."
                               Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="20,0,0,0" />

                    <Separator Margin="0,18,0,10" />
                    <TextBlock Text="Maintenance" Style="{StaticResource SectionTitle}" />
                    <CheckBox x:Name="StartAtLoginBox" Content="Start gujiguji when I sign in"
                              Click="OnStartAtLoginChanged" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="CheckUpdatesButton" Content="Check for updates"
                                Style="{StaticResource SecondaryButton}" Click="OnCheckForUpdates" />
                        <Button x:Name="InstallUpdateButton" Content="Update now"
                                Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                                Visibility="Collapsed" Click="OnInstallUpdate" />
                        <Button Content="Open log" Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0" Click="OnOpenLog" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="1" Grid.Row="1" Background="#F3F3F3"
                BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"
                           Text="Settings saved" TextWrapping="Wrap" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="CancelButton" Content="Close" Style="{StaticResource SecondaryButton}"
                            MinWidth="86"
                            Click="OnCancel" />
                    <Button x:Name="SaveButton" Content="Save changes" Style="{StaticResource PrimaryButton}"
                            MinWidth="112" Margin="8,0,0,0" Click="OnSave" IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

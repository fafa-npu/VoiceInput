<Window x:Class="VoiceInput.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="gujiguji 快速设置"
        Width="900" Height="650" MinWidth="720" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Background="#FFFFFF"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AutomationProperties.Name="gujiguji 首次使用引导"
        PreviewKeyDown="OnPreviewKeyDown"
        PreviewKeyUp="OnPreviewKeyUp">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#146B5D" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0D5549" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E4F2EE" />
        <SolidColorBrush x:Key="TextBrush" Color="#1C2730" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#63717A" />
        <SolidColorBrush x:Key="LineBrush" Color="#D5DCDF" />
        <SolidColorBrush x:Key="BlueBrush" Color="#2868AD" />
        <SolidColorBrush x:Key="BlueSoftBrush" Color="#E8F0FA" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#1E744C" />
        <SolidColorBrush x:Key="SuccessSoftBrush" Color="#E7F4EC" />
        <SolidColorBrush x:Key="AmberBrush" Color="#A65F1F" />
        <SolidColorBrush x:Key="AmberSoftBrush" Color="#FFF3E6" />

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#B9C5CA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F2F5F6" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource BlueBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentDarkBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource BlueBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#D8E0E2" />
                                <Setter Property="Foreground" Value="#7C898F" />
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuietButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#526169" />
        </Style>

        <Style x:Key="StepBorder" TargetType="Border">
            <Setter Property="MinHeight" Value="58" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="4" />
            <RowDefinition Height="*" />
            <RowDefinition Height="64" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="30" Height="30" CornerRadius="6" Background="#DFFF52">
                    <Viewbox Width="22" Height="22">
                        <Canvas Width="64" Height="64">
                            <Line X1="13" Y1="32" X2="18" Y2="32" Stroke="#171A1D" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line X1="22" Y1="24" X2="22" Y2="40" Stroke="#171A1D" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line X1="30" Y1="16" X2="30" Y2="48" Stroke="#171A1D" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line X1="38" Y1="23" X2="38" Y2="41" Stroke="#171A1D" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line X1="46" Y1="30" X2="46" Y2="34" Stroke="#171A1D" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Rectangle Canvas.Left="50" Canvas.Top="18" Width="6" Height="28" RadiusX="3" RadiusY="3" Fill="#237A52" />
                        </Canvas>
                    </Viewbox>
                </Border>
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="Bahnschrift, Segoe UI"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           Text="gujiguji" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Margin="0,0,7,0" Fill="#3CA270" />
                <TextBlock VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="正在系统托盘运行" />
                <TextBlock x:Name="StepCountText"
                           Width="42"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#46555E"
                           Text="1 / 2"
                           TextAlignment="Right" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Background="#E5EAEC">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Background="{StaticResource AccentBrush}" />
            <Border x:Name="ProgressSecondHalf" Grid.Column="1" Background="#E5EAEC" />
        </Grid>

        <ScrollViewer x:Name="PracticePage"
                      Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="False"
                      AutomationProperties.Name="gujiguji 语音输入演练">
            <Grid Margin="30,16,30,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="Bahnschrift, Segoe UI"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Text="说一句，看看它如何输入" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="gujiguji 会把你说的话输入到当前有光标的文本框。先在下面的记事本中试一次。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border x:Name="LocalModelSetupPanel"
                        Grid.Row="1"
                        Margin="0,12,0,0"
                        Padding="14,11"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="#ACCCC3"
                        BorderThickness="1"
                        CornerRadius="6"
                        AutomationProperties.Name="本地模型设置">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="38" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="32" Height="32" CornerRadius="6" Background="{StaticResource AccentBrush}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Foreground="White"
                                       Text="&#xE9D9;" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,18,0" VerticalAlignment="Center">
                            <TextBlock x:Name="LocalModelTitleText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Text="使用推荐的本地模型" />
                            <TextBlock x:Name="LocalModelStatusText"
                                       Margin="0,3,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />
                            <ProgressBar x:Name="LocalModelProgressBar"
                                         Height="6"
                                         Margin="0,8,0,0"
                                         Minimum="0"
                                         Maximum="100"
                                         Visibility="Collapsed"
                                         AutomationProperties.Name="本地模型安装进度" />
                            <TextBlock x:Name="LocalModelProgressText"
                                       Margin="0,4,0,0"
                                       FontSize="10"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Visibility="Collapsed"
                                       AutomationProperties.LiveSetting="Polite" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="CancelLocalModelInstallButton"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="取消"
                                    Visibility="Collapsed"
                                    Click="OnCancelLocalModelInstallClick" />
                            <Button x:Name="InstallLocalModelButton"
                                    MinWidth="116"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource PrimaryButton}"
                                    Content="下载并使用"
                                    AutomationProperties.Name="下载并使用推荐的本地模型"
                                    Click="OnInstallLocalModelClick" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="ActivationModePanel"
                        Grid.Row="2"
                        Margin="0,10,0,0"
                        Padding="13,10"
                        Background="#F8FAFB"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        AutomationProperties.Name="选择说话方式">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                       Text="选择说话方式" />
                            <TextBlock x:Name="LocalModelInlineStatusText"
                                       Margin="0,3,12,0" FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                       Text="设置后立即在下方试用" TextWrapping="Wrap" />
                        </StackPanel>
                        <RadioButton x:Name="HoldModeRadio"
                                     Grid.Column="1"
                                     GroupName="OnboardingPttMode"
                                     Padding="6,2"
                                     VerticalAlignment="Center"
                                     Checked="OnPttModeChanged">
                            <StackPanel Margin="5,0,10,0">
                                <TextBlock FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                           Text="按住说话" />
                                <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                           Text="按住时聆听，松开后输入" TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="ToggleModeRadio"
                                     Grid.Column="2"
                                     GroupName="OnboardingPttMode"
                                     Padding="6,2"
                                     VerticalAlignment="Center"
                                     Checked="OnPttModeChanged">
                            <StackPanel Margin="5,0,0,0">
                                <TextBlock FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                           Text="按一下开始 / 再按一下结束" TextWrapping="Wrap" />
                                <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{StaticResource MutedTextBrush}"
                                           Text="无需一直按住按键" TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>
                    </Grid>
                </Border>

                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel AutomationProperties.Name="语音输入的三个步骤">
                        <Border x:Name="FocusStep"
                                Style="{StaticResource StepBorder}"
                                Background="{StaticResource BlueSoftBrush}"
                                BorderBrush="{StaticResource BlueBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="FocusStepBadge" Width="27" Height="27" CornerRadius="14"
                                        Background="{StaticResource BlueBrush}">
                                    <TextBlock x:Name="FocusStepNumberText" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="Bold" Foreground="White" Text="1" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="9,0,0,0">
                                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                               Text="点击文本框" />
                                    <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                               Text="先把光标放到需要输入的位置" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border x:Name="TalkStep" Style="{StaticResource StepBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="TalkStepBadge" Width="27" Height="27" CornerRadius="14"
                                        BorderBrush="#AEBAC0" BorderThickness="1">
                                    <TextBlock x:Name="TalkStepNumberText" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="Bold" Foreground="#65747C" Text="2" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="9,0,0,0">
                                    <TextBlock x:Name="PracticePttStepText"
                                               FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="PracticePttStepDetailText"
                                               Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                               Text="按住时 gujiguji 才会聆听" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border x:Name="ReleaseStep" Style="{StaticResource StepBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ReleaseStepBadge" Width="27" Height="27" CornerRadius="14"
                                        BorderBrush="#AEBAC0" BorderThickness="1">
                                    <TextBlock x:Name="ReleaseStepNumberText" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="Bold" Foreground="#65747C" Text="3" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="9,0,0,0">
                                    <TextBlock x:Name="PracticeReleaseStepText"
                                               FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                               Text="松开即可输入" />
                                    <TextBlock x:Name="PracticeReleaseStepDetailText"
                                               Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                               Text="文字会回到刚才的光标位置" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Border Height="158"
                                BorderBrush="#AEB9BE"
                                BorderThickness="1"
                                CornerRadius="6"
                                ClipToBounds="True"
                                Background="White">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="24" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="22" />
                                </Grid.RowDefinitions>
                                <Grid Background="#F3F5F6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="18" Height="18" Margin="9,0,7,0"
                                            VerticalAlignment="Center" Background="#D9E9F8">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="10" FontWeight="Bold" Foreground="{StaticResource BlueBrush}" Text="N" />
                                    </Border>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11"
                                               Foreground="#3F4B52" Text="无标题 - 记事本" />
                                    <TextBlock Grid.Column="2" Margin="0,0,9,0" VerticalAlignment="Center"
                                               FontSize="11" Foreground="#5D6870" Text="&#x2014;   &#x25A1;   &#x00D7;" />
                                </Grid>
                                <TextBlock Grid.Row="1" Padding="10,5,0,0" FontSize="10" Foreground="#3F4B52"
                                           Text="文件    编辑    查看" />
                                <Grid Grid.Row="2">
                                    <TextBox x:Name="PracticeTextBox"
                                             Padding="12,9"
                                             AcceptsReturn="True"
                                             BorderBrush="#E2E6E8"
                                             BorderThickness="0,1"
                                             FontFamily="Consolas"
                                             FontSize="14"
                                             Foreground="#20272C"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             AutomationProperties.Name="语音输入演练文本框"
                                             AutomationProperties.HelpText="点击这里，按住已配置的说话键，说完后松开。"
                                             GotKeyboardFocus="OnPracticeTextBoxGotKeyboardFocus"
                                             TextChanged="OnPracticeTextChanged" />
                                    <TextBlock Margin="13,10"
                                               IsHitTestVisible="False"
                                               FontFamily="Consolas"
                                               FontSize="13"
                                               Foreground="#8A969C"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Text" Value="点击这里，然后按住说话键开始说话" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=PracticeTextBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Grid.Row="3" Padding="0,4,9,0" Background="#F7F8F8"
                                           FontSize="9" Foreground="#748087" Text="第 1 行，第 1 列    100%    UTF-8"
                                           TextAlignment="Right" />
                            </Grid>
                        </Border>

                        <Grid Margin="0,8,0,0" MinHeight="54">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="KeycapBorder"
                                    Width="88" Height="58"
                                    HorizontalAlignment="Left"
                                    Background="#F8FAFB"
                                    BorderBrush="#87959C"
                                    BorderThickness="1,1,1,4"
                                    CornerRadius="7"
                                    AutomationProperties.Name="当前说话键">
                                <TextBlock x:Name="PttKeyText"
                                           Margin="6"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#26343C"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </Border>
                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="PracticeStatusDot" Width="9" Height="9" Margin="0,0,9,0"
                                             VerticalAlignment="Center" Fill="#9DA8AD" />
                                    <TextBlock x:Name="PracticeStatusText"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               Text="先点击上面的文本框"
                                               AutomationProperties.LiveSetting="Polite" />
                                </StackPanel>
                                <TextBlock x:Name="PracticeStatusDetailText"
                                           Grid.Row="1"
                                           Margin="18,4,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="光标出现后，再按住键盘上的说话键。"
                                           TextWrapping="Wrap" />
                                <StackPanel x:Name="ListeningBars" Grid.Row="2" Margin="18,7,0,0"
                                            Orientation="Horizontal" Visibility="Collapsed">
                                    <Border Width="3" Height="7" Margin="0,0,3,0" CornerRadius="2" Background="{StaticResource AccentBrush}" />
                                    <Border Width="3" Height="13" Margin="0,0,3,0" CornerRadius="2" Background="{StaticResource AccentBrush}" />
                                    <Border Width="3" Height="9" Margin="0,0,3,0" CornerRadius="2" Background="{StaticResource AccentBrush}" />
                                    <Border Width="3" Height="16" Margin="0,0,3,0" CornerRadius="2" Background="{StaticResource AccentBrush}" />
                                    <Border Width="3" Height="8" CornerRadius="2" Background="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="4"
                        Margin="0,12,0,0"
                        Padding="0,11"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="24" Height="24" Margin="0,0,10,0" CornerRadius="12"
                                Background="{StaticResource SuccessSoftBrush}">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Text="&#x2713;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                       Text="默认使用本地语音识别" />
                            <TextBlock x:Name="CurrentSummaryText" Margin="0,2,14,0" FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                            <Hyperlink x:Name="OpenSettingsLink"
                                       Foreground="{StaticResource BlueBrush}"
                                       TextDecorations="None"
                                       AutomationProperties.Name="更改语言、热键、识别引擎或模型"
                                       Click="OnOpenSettingsClick">更改语言、热键、引擎或模型</Hyperlink>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <ScrollViewer x:Name="CompletionPage"
                      Grid.Row="2"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="False"
                      AutomationProperties.Name="gujiguji 设置完成页面">
            <Grid Margin="34,18,34,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource SuccessSoftBrush}">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="20" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Text="&#x2713;" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock FontFamily="Bahnschrift, Segoe UI"
                                   FontSize="27"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="gujiguji 已准备好" />
                        <TextBlock x:Name="CompletionSummaryText"
                                   Margin="0,5,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,12,0,0" AutomationProperties.Name="gujiguji 使用步骤回顾">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="26" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="26" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="10,8" Background="#F8FAFB" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="22" Height="22" CornerRadius="11" Background="{StaticResource BlueSoftBrush}">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"
                                           FontWeight="Bold" Foreground="{StaticResource BlueBrush}" Text="1" />
                            </Border>
                            <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" FontSize="11" Text="点击文本框" />
                        </StackPanel>
                    </Border>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#9AA5AA" Text="&#x2192;" />
                    <Border Grid.Column="2" Padding="10,8" Background="#F8FAFB" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="22" Height="22" CornerRadius="11" Background="{StaticResource BlueSoftBrush}">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"
                                           FontWeight="Bold" Foreground="{StaticResource BlueBrush}" Text="2" />
                            </Border>
                            <TextBlock x:Name="CompletionTalkStepText" Margin="7,0,0,0"
                                       VerticalAlignment="Center" FontSize="11" Text="按住说话" />
                        </StackPanel>
                    </Border>
                    <TextBlock Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#9AA5AA" Text="&#x2192;" />
                    <Border Grid.Column="4" Padding="10,8" Background="#F8FAFB" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="22" Height="22" CornerRadius="11" Background="{StaticResource BlueSoftBrush}">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"
                                           FontWeight="Bold" Foreground="{StaticResource BlueBrush}" Text="3" />
                            </Border>
                            <TextBlock x:Name="CompletionSubmitStepText" Margin="7,0,0,0"
                                       VerticalAlignment="Center" FontSize="11" Text="松开输入" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Margin="0,14,0,0" MinHeight="126"
                        Background="#F8FAFB" BorderBrush="#D9E0E2" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource BlueBrush}" />
                        <Grid Grid.Column="1" Margin="17,12,14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="286" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,4,18,0" VerticalAlignment="Top">
                                <TextBlock FontFamily="Bahnschrift, Segoe UI" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" Text="关闭引导后，gujiguji 仍会在系统托盘运行"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                           Text="需要暂停、修改设置或退出时，在任务栏右下角找到 gujiguji 图标并打开菜单。"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Grid x:Name="TrayMenuMock" Grid.Column="1" Height="106"
                                  AutomationProperties.Name="系统托盘菜单示例">
                                <Border Height="38" VerticalAlignment="Bottom" Background="#202326">
                                    <StackPanel Margin="0,0,10,0" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Margin="0,0,13,0" VerticalAlignment="Center" FontSize="16" Foreground="#F3F6F7" Text="&#x2303;" />
                                        <Border Width="18" Height="18" Margin="0,0,13,0" VerticalAlignment="Center"
                                                CornerRadius="4" Background="#DFFF52">
                                            <Viewbox Width="14" Height="14">
                                                <Canvas Width="64" Height="64">
                                                    <Line X1="13" Y1="32" X2="18" Y2="32" Stroke="#171A1D" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="22" Y1="24" X2="22" Y2="40" Stroke="#171A1D" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="30" Y1="16" X2="30" Y2="48" Stroke="#171A1D" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="38" Y1="23" X2="38" Y2="41" Stroke="#171A1D" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="46" Y1="30" X2="46" Y2="34" Stroke="#171A1D" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Rectangle Canvas.Left="50" Canvas.Top="18" Width="6" Height="28" RadiusX="3" RadiusY="3" Fill="#237A52" />
                                                </Canvas>
                                            </Viewbox>
                                        </Border>
                                        <TextBlock VerticalAlignment="Center" FontSize="10" Foreground="#DFE5E7" Text="15:42&#x0a;7/15/2026"
                                                   TextAlignment="Right" />
                                    </StackPanel>
                                </Border>
                                <Border Width="154" Margin="0,0,54,33"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Padding="6" Background="White" BorderBrush="#B9C1C5" BorderThickness="1"
                                        Panel.ZIndex="2">
                                    <StackPanel>
                                        <TextBlock Padding="7,3" FontSize="10" FontWeight="SemiBold" Text="gujiguji" />
                                        <TextBlock Padding="7,3" FontSize="10" Text="暂停聆听" />
                                        <TextBlock Padding="7,3" Background="{StaticResource BlueSoftBrush}"
                                                   FontSize="10" Foreground="#245A92" Text="设置…" />
                                        <Border Height="1" Margin="5,3" Background="#D9DFE2" />
                                        <TextBlock Padding="7,3" FontSize="10" Text="退出" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Margin="0,14,0,0" Padding="15"
                        Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="38" Height="38" CornerRadius="6" Background="{StaticResource AmberSoftBrush}">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="{StaticResource AmberBrush}"
                                       Text="&#xE713;" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,15,0" VerticalAlignment="Center">
                            <TextBlock FontFamily="Bahnschrift, Segoe UI" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" Text="可选的语音与输入设置" />
                            <TextBlock x:Name="CompletionLocalModelText"
                                       Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                       Text="当前使用推荐的本地模型；也可在设置中切换其他本地模型、云端引擎、语言和热键。"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button x:Name="CompletionOpenSettingsButton"
                                Grid.Column="2"
                                Style="{StaticResource SecondaryButton}"
                                VerticalAlignment="Center"
                                Content="打开设置"
                                AutomationProperties.Name="打开设置"
                                Click="OnOpenSettingsClick" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="3" Background="#FAFBFB" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid x:Name="PracticeFooter" Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="SkipButton"
                            HorizontalAlignment="Left"
                            Style="{StaticResource QuietButton}"
                            Content="跳过演练"
                            AutomationProperties.Name="跳过首次使用演练"
                            Click="OnSkipClick" />
                    <Button x:Name="ContinueButton"
                            Grid.Column="1"
                            MinWidth="108"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="False"
                            Content="继续"
                            AutomationProperties.Name="继续查看完成页面"
                            Click="OnContinueClick" />
                </Grid>

                <Grid x:Name="CompletionFooter" Margin="24,0" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="PracticeAgainButton"
                            HorizontalAlignment="Left"
                            Style="{StaticResource QuietButton}"
                            Content="再练一次"
                            AutomationProperties.Name="再次练习语音输入"
                            Click="OnPracticeAgainClick" />
                    <Button x:Name="FinishButton"
                            Grid.Column="1"
                            MinWidth="206"
                            Style="{StaticResource PrimaryButton}"
                            Content="关闭引导并开始使用"
                            AutomationProperties.Name="关闭引导并开始使用 gujiguji"
                            Click="OnFinishClick" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
